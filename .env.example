ANTHROPIC_API_KEY=

# Brand customisation — both inlined at build time, redeploy after changing.
# Default brand is "Reckon" with the logo at /public/brand/logo.svg.
NEXT_PUBLIC_BRAND_NAME=Reckon
NEXT_PUBLIC_BRAND_LOGO=/brand/logo.svg

# SQLite path (relative to project root). Created on first boot.
AGENT_DB_PATH=./data/agent.db

# Soft cost cap per run. When cumulative cost exceeds this, the run aborts.
AGENT_COST_CAP_USD=5.00

# GraphJin server (used at boot to prefetch the knowledge pack via /discover/<section>).
# Token optional — set if your GraphJin server requires auth.
GRAPHJIN_BASE_URL=http://localhost:8080
GRAPHJIN_TOKEN=

# Knowledge pack fetch behaviour.
DISCOVERY_TIMEOUT_MS=10000
DISCOVERY_RETRIES=3

# Default timezone for cron schedules when a workflow doesn't specify one.
DEFAULT_TIMEZONE=UTC

# Default Anthropic model.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Bind address for the Next.js server. Defaults to 127.0.0.1 (loopback only).
# Set to 0.0.0.0 ONLY when the network already restricts ingress (e.g. a
# VPN-only box, or behind a reverse proxy with auth). v1 has no app-level auth.
# HOST=127.0.0.1

# Direct Postgres connection used ONLY by the smoke test harness for ground
# truth verification. The agent itself never touches this — it goes through
# graphjin cli.
TEST_DB_URL=
